{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JWT": {
    "Key": "BankingAPI_JWT_SECRET_KEY_2026_SUPER_LONG_32_PLUS_CHARS",
    "Issuer": "G3 Server",
    "DurationInMinutes": 60
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=BankingAPI;Username=postgres;Password=12345; Include Error Detail=true"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/MyAppLog-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "BankingAPI"
    }
  },
  "AllowedHosts": "*"
}
